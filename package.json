{
  "name": "cc-buddy-rehatch",
  "version": "0.1.0",
  "description": "Rehatch your Claude Code buddy by searching for a matching salt and patching the local binary",
  "type": "module",
  "bin": {
    "cc-buddy-rehatch": "src/cli.ts"
  },
  "files": [
    "src",
    "docs",
    "fixtures",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun test"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "license": "MIT",
  "keywords": [
    "claude",
    "claude-code",
    "buddy",
    "companion",
    "rehatch",
    "patch"
  ],
  "dependencies": {
    "chalk": "^5.6.2",
    "ink": "^6.8.0",
    "jsonc-parser": "^3.3.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^19.2.2",
    "bun-types": "^1.3.11",
    "typescript": "^5.8.3"
  }
}
